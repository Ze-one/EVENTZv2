# ------------------------------------------------------------------------------
# ETSNTECH PASS SYSTEM ENVIRONMENT VARIABLES
# Copy this file to '.env.local' locally, or add the same values in Vercel.
# ------------------------------------------------------------------------------

# --- SUPABASE CONFIGURATION (POSTGRESQL REAL DATABASE) ---
# Required for production persistence. Without Supabase, Vercel can lose local JSON data.
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- APP PUBLIC URL ---
# Required so emailed QR codes point to the deployed app verification page.
# Example: https://your-app.vercel.app or https://events.yourdomain.com
APP_BASE_URL=https://your-deployed-app-url

# --- SENDGRID CONFIGURATION (RECOMMENDED FOR VERCEL) ---
# Use a verified SendGrid sender. The sender must be verified in SendGrid.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM="ETS N-TECH" <verified_sender@yourdomain.com>

# --- SMTP FALLBACK CONFIGURATION (OPTIONAL ALTERNATIVE TO SENDGRID) ---
# Use these only if you are not using SendGrid.
SMTP_HOST=your_smtp_server_host
SMTP_PORT=587
SMTP_USER=your_smtp_sender_username
SMTP_PASS=your_smtp_sender_password
SMTP_FROM="ETS N-TECH" <verified_sender@yourdomain.com>
