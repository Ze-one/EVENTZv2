# ------------------------------------------------------------------------------
# ETSNTECH PASS SYSTEM ENVIRONMENT VARIABLES
# Copy this file to '.env' and fill in your credentials.
# ------------------------------------------------------------------------------

# --- SUPABASE CONFIGURATION (POSTGRESQL REAL DATABASE) ---
# Paste your Supabase project credentials below.
# The app automatically self-seeds default data (admin account, event) when connected.
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- SMTP MAIL SERVER CONFIGURATION ---
# (Optional) For sending real emails with PDF/PNG entrance passes to delegates.
# If not provided, the application defaults to a secure simulation delivery.
SMTP_HOST=your_smtp_server_host
SMTP_PORT=587
SMTP_USER=your_smtp_sender_username
SMTP_PASS=your_smtp_sender_password
SMTP_FROM="ETS N-TECH Tech Summit" <your_sender_verified_email>
