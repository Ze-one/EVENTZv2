{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/account-management",
      "destination": "/api/account-management.ts"
    },
    {
      "source": "/api/scan-logs/clear",
      "destination": "/api/clear-scan-logs.ts"
    },
    {
      "source": "/api/email-logs/clear",
      "destination": "/api/clear-email-logs.ts"
    },
    {
      "source": "/api/verify/:passId/claim",
      "destination": "/api/claim-pass.ts?passId=:passId"
    },
    {
      "source": "/api/participants/:id/email",
      "destination": "/api/participant-email.ts?id=:id"
    },
    {
      "source": "/api/participants/bulk-email",
      "destination": "/api/bulk-email.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api|assets|favicon.ico|manifest.json).*)",
      "destination": "/index.html"
    }
  ]
}
